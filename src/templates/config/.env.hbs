# Application
NODE_ENV={{environment}}
PORT={{port}}
APP_NAME={{appName}}

# Database
{{#if requirements.database}}
DATABASE_URL=postgresql://{{dbUser}}:{{dbPassword}}@{{dbHost}}:{{dbPort}}/{{dbName}}
DB_HOST={{dbHost}}
DB_PORT={{dbPort}}
DB_USER={{dbUser}}
DB_PASSWORD={{dbPassword}}
DB_NAME={{dbName}}
{{/if}}

# Authentication
{{#if requirements.auth}}
JWT_SECRET={{jwtSecret}}
JWT_EXPIRES_IN=24h
SESSION_SECRET={{sessionSecret}}
{{/if}}

# External Services
{{#if externalServices}}
{{#each externalServices}}
{{@key}}_API_URL={{this.url}}
{{@key}}_API_KEY={{this.key}}
{{/each}}
{{/if}}

# Logging
LOG_LEVEL=info

# CORS
CORS_ORIGIN={{corsOrigin}}
