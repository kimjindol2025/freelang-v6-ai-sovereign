{
  "name": "{{projectName}}",
  "version": "1.0.0",
  "description": "{{description}}",
  "main": "dist/{{mainFile}}.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/{{mainFile}}.js",
    "dev": "ts-node src/{{mainFile}}.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "express": "^4.18.2",
    "dotenv": "^16.0.0",
    "helmet": "^7.0.0",
    "cors": "^2.8.5",
    {{#if requirements.database}}
    "pg": "^8.8.0",
    {{/if}}
    {{#if requirements.auth}}
    "jsonwebtoken": "^9.0.0",
    "bcryptjs": "^2.4.3",
    {{/if}}
    {{#if requirements.validation}}
    "zod": "^3.20.0",
    {{/if}}
    "axios": "^1.4.0"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.0.0",
    "typescript": "^5.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "ts-node": "^10.9.0",
    "eslint": "^8.0.0",
    "@typescript-eslint/parser": "^5.0.0",
    "@typescript-eslint/eslint-plugin": "^5.0.0",
    "prettier": "^2.8.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
