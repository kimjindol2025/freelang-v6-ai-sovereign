{
  "version": "6.0",
  "description": "Claude 분석 패턴 - 코드 오류 분류",
  "instructions": [
    {
      "type": "comment",
      "text": "Claude의 코드 리뷰: 오류 분류 및 심각도 필터링"
    },
    {
      "type": "var",
      "name": "errors",
      "value_type": "Array<i32>",
      "value": {
        "type": "array",
        "elements": [
          {"type": "literal", "value_type": "i32", "value": 1},
          {"type": "literal", "value_type": "i32", "value": 2},
          {"type": "literal", "value_type": "i32", "value": 3},
          {"type": "literal", "value_type": "i32", "value": 1},
          {"type": "literal", "value_type": "i32", "value": 2}
        ]
      }
    },
    {
      "type": "call",
      "function": "Array.filter",
      "args": [
        {"type": "ref", "name": "errors"},
        {
          "type": "lambda",
          "params": [{"name": "severity", "type": "i32"}],
          "body": [
            {
              "type": "comparison",
              "operator": ">=",
              "left": {"type": "ref", "name": "severity"},
              "right": {"type": "literal", "value_type": "i32", "value": 2}
            }
          ]
        }
      ],
      "assign_to": "critical_errors"
    },
    {
      "type": "call",
      "function": "IO.print",
      "args": [
        {
          "type": "call",
          "function": "String.join",
          "args": [
            {
              "type": "array",
              "elements": [
                {"type": "literal", "value_type": "string", "value": "Critical errors found: "},
                {"type": "ref", "name": "critical_errors"}
              ]
            },
            {"type": "literal", "value_type": "string", "value": ""}
          ]
        }
      ]
    }
  ]
}
