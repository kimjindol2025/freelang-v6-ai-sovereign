{
  "version": "6.0",
  "description": "Claude 문제 해결 - 디버깅 프로세스",
  "instructions": [
    {
      "type": "comment",
      "text": "디버깅 프로세스: 테스트 케이스 분석 및 실패 감지"
    },
    {
      "type": "var",
      "name": "test_results",
      "value_type": "Array<i32>",
      "value": {
        "type": "array",
        "elements": [
          {"type": "literal", "value_type": "i32", "value": 1},
          {"type": "literal", "value_type": "i32", "value": 1},
          {"type": "literal", "value_type": "i32", "value": 0},
          {"type": "literal", "value_type": "i32", "value": 1},
          {"type": "literal", "value_type": "i32", "value": 0}
        ]
      }
    },
    {
      "type": "call",
      "function": "Array.reduce",
      "args": [
        {"type": "ref", "name": "test_results"},
        {
          "type": "lambda",
          "params": [
            {"name": "passed", "type": "i32"},
            {"name": "result", "type": "i32"}
          ],
          "body": [
            {
              "type": "arithmetic",
              "operator": "+",
              "left": {"type": "ref", "name": "passed"},
              "right": {"type": "ref", "name": "result"}
            }
          ]
        },
        {"type": "literal", "value_type": "i32", "value": 0}
      ],
      "assign_to": "passed_count"
    },
    {
      "type": "call",
      "function": "Array.length",
      "args": [{"type": "ref", "name": "test_results"}],
      "assign_to": "total_tests"
    },
    {
      "type": "call",
      "function": "IO.print",
      "args": [
        {
          "type": "call",
          "function": "String.join",
          "args": [
            {
              "type": "array",
              "elements": [
                {"type": "literal", "value_type": "string", "value": "Tests: "},
                {"type": "ref", "name": "passed_count"},
                {"type": "literal", "value_type": "string", "value": "/"},
                {"type": "ref", "name": "total_tests"}
              ]
            },
            {"type": "literal", "value_type": "string", "value": ""}
          ]
        }
      ]
    }
  ]
}
