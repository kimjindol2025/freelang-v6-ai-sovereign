{
  "version": "6.0",
  "description": "조건문과 반복문 결합 예제",
  "instructions": [
    {
      "type": "var",
      "name": "numbers",
      "value_type": "Array<i32>",
      "value": {
        "type": "array",
        "elements": [
          {"type": "literal", "value_type": "i32", "value": 1},
          {"type": "literal", "value_type": "i32", "value": 2},
          {"type": "literal", "value_type": "i32", "value": 3},
          {"type": "literal", "value_type": "i32", "value": 4},
          {"type": "literal", "value_type": "i32", "value": 5}
        ]
      }
    },
    {
      "type": "loop",
      "iterator": "num",
      "range": {"type": "ref", "name": "numbers"},
      "body": [
        {
          "type": "condition",
          "test": {
            "type": "comparison",
            "operator": "%",
            "left": {"type": "ref", "name": "num"},
            "right": {"type": "literal", "value_type": "i32", "value": 2}
          },
          "then": [
            {
              "type": "call",
              "function": "IO.print",
              "args": [
                {
                  "type": "call",
                  "function": "String.join",
                  "args": [
                    {
                      "type": "array",
                      "elements": [
                        {"type": "literal", "value_type": "string", "value": "Odd: "},
                        {"type": "ref", "name": "num"}
                      ]
                    },
                    {"type": "literal", "value_type": "string", "value": ""}
                  ]
                }
              ]
            }
          ],
          "else": [
            {
              "type": "call",
              "function": "IO.print",
              "args": [
                {
                  "type": "call",
                  "function": "String.join",
                  "args": [
                    {
                      "type": "array",
                      "elements": [
                        {"type": "literal", "value_type": "string", "value": "Even: "},
                        {"type": "ref", "name": "num"}
                      ]
                    },
                    {"type": "literal", "value_type": "string", "value": ""}
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
