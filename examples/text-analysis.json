{
  "version": "6.0",
  "description": "텍스트 분석 예제",
  "instructions": [
    {
      "type": "var",
      "name": "text",
      "value_type": "string",
      "value": "Hello World Hello AI Hello CLAUDELang"
    },
    {
      "type": "call",
      "function": "String.split",
      "args": [
        {"type": "ref", "name": "text"},
        {"type": "literal", "value_type": "string", "value": " "}
      ],
      "assign_to": "words"
    },
    {
      "type": "call",
      "function": "Array.length",
      "args": [{"type": "ref", "name": "words"}],
      "assign_to": "word_count"
    },
    {
      "type": "call",
      "function": "IO.print",
      "args": [
        {
          "type": "call",
          "function": "String.join",
          "args": [
            {"type": "ref", "name": "words"},
            {"type": "literal", "value_type": "string", "value": ", "}
          ]
        }
      ]
    },
    {
      "type": "call",
      "function": "IO.print",
      "args": [{"type": "ref", "name": "word_count"}]
    }
  ]
}
