{
  "version": "6.0",
  "instructions": [
    {
      "type": "comment",
      "text": "API 응답 처리 예제 - 사용자 데이터 필터링 및 정렬"
    },
    {
      "type": "var",
      "name": "api_response",
      "value_type": "Array<Object>",
      "value": {
        "type": "array",
        "elements": [
          {
            "type": "object",
            "properties": {
              "id": {"type": "literal", "value_type": "i32", "value": 1},
              "name": {"type": "literal", "value_type": "string", "value": "Alice"},
              "age": {"type": "literal", "value_type": "i32", "value": 30},
              "active": {"type": "literal", "value_type": "boolean", "value": true}
            }
          },
          {
            "type": "object",
            "properties": {
              "id": {"type": "literal", "value_type": "i32", "value": 2},
              "name": {"type": "literal", "value_type": "string", "value": "Bob"},
              "age": {"type": "literal", "value_type": "i32", "value": 22},
              "active": {"type": "literal", "value_type": "boolean", "value": false}
            }
          },
          {
            "type": "object",
            "properties": {
              "id": {"type": "literal", "value_type": "i32", "value": 3},
              "name": {"type": "literal", "value_type": "string", "value": "Charlie"},
              "age": {"type": "literal", "value_type": "i32", "value": 35},
              "active": {"type": "literal", "value_type": "boolean", "value": true}
            }
          }
        ]
      }
    },
    {
      "type": "comment",
      "text": "활성 사용자만 필터링 (active == true)"
    },
    {
      "type": "call",
      "function": "Array.filter",
      "args": [
        {"type": "ref", "name": "api_response"},
        {
          "type": "lambda",
          "params": ["user"],
          "body": [
            {
              "type": "property_access",
              "object": {"type": "ref", "name": "user"},
              "property": "active"
            }
          ]
        }
      ],
      "assign_to": "active_users"
    },
    {
      "type": "comment",
      "text": "각 사용자의 이름만 추출"
    },
    {
      "type": "call",
      "function": "Array.map",
      "args": [
        {"type": "ref", "name": "active_users"},
        {
          "type": "lambda",
          "params": ["user"],
          "body": [
            {
              "type": "property_access",
              "object": {"type": "ref", "name": "user"},
              "property": "name"
            }
          ]
        }
      ],
      "assign_to": "active_names"
    },
    {
      "type": "comment",
      "text": "평균 나이 계산"
    },
    {
      "type": "var",
      "name": "total_age",
      "value_type": "i32",
      "value": 0
    },
    {
      "type": "call",
      "function": "Array.reduce",
      "args": [
        {"type": "ref", "name": "active_users"},
        {"type": "ref", "name": "total_age"},
        {
          "type": "lambda",
          "params": ["sum", "user"],
          "body": [
            {
              "type": "arithmetic",
              "operator": "+",
              "left": {"type": "ref", "name": "sum"},
              "right": {
                "type": "property_access",
                "object": {"type": "ref", "name": "user"},
                "property": "age"
              }
            }
          ]
        }
      ],
      "assign_to": "total_age"
    },
    {
      "type": "call",
      "function": "Array.length",
      "args": [
        {"type": "ref", "name": "active_users"}
      ],
      "assign_to": "active_count"
    },
    {
      "type": "arithmetic",
      "operator": "/",
      "left": {"type": "ref", "name": "total_age"},
      "right": {"type": "ref", "name": "active_count"},
      "assign_to": "average_age"
    },
    {
      "type": "comment",
      "text": "결과 출력"
    },
    {
      "type": "call",
      "function": "IO.print",
      "args": [
        {"type": "literal", "value_type": "string", "value": "Active users:"}
      ]
    },
    {
      "type": "call",
      "function": "IO.print_array",
      "args": [
        {"type": "ref", "name": "active_names"}
      ]
    },
    {
      "type": "call",
      "function": "IO.print",
      "args": [
        {
          "type": "call",
          "function": "String.concat",
          "args": [
            {"type": "literal", "value_type": "string", "value": "Average age of active users: "},
            {"type": "ref", "name": "average_age"}
          ]
        }
      ]
    }
  ]
}
