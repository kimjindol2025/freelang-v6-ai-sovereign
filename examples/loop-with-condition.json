{
  "version": "6.0",
  "instructions": [
    {
      "type": "comment",
      "text": "조건부 반복 예제 - 조건을 만족하는 항목 찾기"
    },
    {
      "type": "var",
      "name": "temperatures",
      "value_type": "Array<i32>",
      "value": {
        "type": "array",
        "elements": [
          {"type": "literal", "value_type": "i32", "value": 15},
          {"type": "literal", "value_type": "i32", "value": 22},
          {"type": "literal", "value_type": "i32", "value": 28},
          {"type": "literal", "value_type": "i32", "value": 35},
          {"type": "literal", "value_type": "i32", "value": 18},
          {"type": "literal", "value_type": "i32", "value": 30}
        ]
      }
    },
    {
      "type": "comment",
      "text": "높은 온도(25도 이상) 찾기"
    },
    {
      "type": "call",
      "function": "Array.filter",
      "args": [
        {"type": "ref", "name": "temperatures"},
        {
          "type": "lambda",
          "params": ["temp"],
          "body": [
            {
              "type": "comparison",
              "operator": ">=",
              "left": {"type": "ref", "name": "temp"},
              "right": {"type": "literal", "value_type": "i32", "value": 25}
            }
          ]
        }
      ],
      "assign_to": "high_temps"
    },
    {
      "type": "comment",
      "text": "높은 온도의 개수 계산"
    },
    {
      "type": "call",
      "function": "Array.length",
      "args": [
        {"type": "ref", "name": "high_temps"}
      ],
      "assign_to": "count"
    },
    {
      "type": "comment",
      "text": "결과 출력"
    },
    {
      "type": "call",
      "function": "IO.print",
      "args": [
        {"type": "literal", "value_type": "string", "value": "Temperatures >= 25 degrees:"}
      ]
    },
    {
      "type": "call",
      "function": "IO.print_array",
      "args": [
        {"type": "ref", "name": "high_temps"}
      ]
    },
    {
      "type": "call",
      "function": "IO.print",
      "args": [
        {
          "type": "call",
          "function": "String.concat",
          "args": [
            {"type": "literal", "value_type": "string", "value": "Count: "},
