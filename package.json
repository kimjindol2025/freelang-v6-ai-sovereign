{
  "name": "claudelang",
  "version": "1.0.0",
  "description": "CLAUDELang - AI-optimized programming language designed for Claude, expressing programs as pure JSON with functional programming paradigms",
  "main": "src/index.js",
  "type": "module",
  "exports": {
    ".": {
      "import": "./src/index.js",
      "require": "./src/index.js"
    },
    "./compiler": "./src/compiler.js",
    "./runtime": "./src/vt-runtime-bridge.js"
  },
  "scripts": {
    "test": "node test/test-basic.js && node test/vt-runtime.test.js",
    "test:examples": "node run-examples.js",
    "test:patterns": "node test-claude-patterns.js",
    "test:all": "node test/test-basic.js && node test/vt-runtime.test.js && node run-examples.js && node test-claude-patterns.js"
  },
  "keywords": [
    "claude",
    "ai",
    "language",
    "json",
    "compiler",
    "functional-programming",
    "data-processing",
    "vt-runtime"
  ],
  "author": "Claude (Anthropic)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/anthropics/claudelang.git"
  },
  "bugs": {
    "url": "https://github.com/anthropics/claudelang/issues"
  },
  "homepage": "https://github.com/anthropics/claudelang#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "src/",
    "examples/",
    "README.md",
    "LICENSE"
  ]
}
